// Recommendations
app.get('/recommendations/:id', (req, res) => {
  const id = parseInt(req.params.id);
  const source = db.products.find(p => p.id === id) || db.relevantProducts.find(p => p.id === id);
  const sameCategory = source
    ? db.products.filter(p => p.id !== id && p.category === source.category).slice(0, 4)
    : db.products.slice(0, 4);
  const relevantRecs = db.relevantProducts.filter(p => p.id !== id).map(p => ({ ...p, isRelevant: true }));
  const seen = new Set();
  const recommendations = [...sameCategory, ...relevantRecs].filter(p => {
    if (seen.has(p.id)) return false;
    seen.add(p.id);
    return true;
  }).slice(0, 8);
  
  // Ensure all recommendations have Cloudinary URLs
  const recommendationsWithCloudinary = recommendations.map(rec => ({
    ...rec,
    images: rec.images?.filter(url => url && url.includes('cloudinary.com')) || [],
    image: rec.image?.includes('cloudinary.com') ? rec.image : (rec.images?.[0] || null)
  }));
  
  res.json({ success: true, recommendations: recommendationsWithCloudinary });
});

